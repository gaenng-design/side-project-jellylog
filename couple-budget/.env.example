VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# 정규화 DB(year_month 등 snake_case)는 코드 기본값이 이미 snake_case.
# 구형 quoted camelColumn 테이블만: VITE_SUPABASE_REPO_COLUMNS=camelCase
# VITE_SUPABASE_REPO_COLUMNS=snake_case

# incomes만 초기 스키마 컬럼 "yearMonth"이고 다른 테이블은 snake_case일 때 (year_month NOT NULL 오류 방지)
# VITE_SUPABASE_INCOMES_LEGACY_YEAR_MONTH=true

# separate_items: 스키마 캐시에 year_month 가 없다 / Could not find the 'year_month' column
# → Supabase SQL Editor 에서 supabase-migration-separate-items-rename-year-month.sql 실행(권장)
# 또는 임시로 아래 true (DB를 snake_case 로 맞춘 뒤에는 제거)
# VITE_SUPABASE_SEPARATE_ITEMS_LEGACY_CAMEL=true

# separate_person 컬럼이 DB에 아직 없어 저장이 막힐 때 임시(태그·별도정산 필드 미동기화) — 곧 아래 SQL 실행 후 제거
# VITE_SUPABASE_SEPARATE_ITEMS_STRIP_EXTENDED_COLUMNS=true

# incomes upsert: 기본은 PK `id`. DB에 복합 유니크를 추가한 경우에만 예시처럼 설정
# VITE_SUPABASE_INCOMES_ON_CONFLICT=household_id,year_month,person,category

# 코드 동기화(기본): Dashboard → Authentication → Providers → Anonymous 활성화
# 기기 변경·복구용으로만 Email 사용 시 Email 도 활성화
# 가계·RLS: 기본 스키마 후 supabase-migration-household-auth.sql 만 실행 (통합 최종본)
