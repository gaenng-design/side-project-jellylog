# GitHub Configuration for Data Sync
# Create a Personal Access Token at: https://github.com/settings/tokens
# Required scopes: repo (for private repositories)
# VITE_GITHUB_TOKEN=your_github_personal_access_token

# GitHub repository details
# VITE_GITHUB_OWNER=your_github_username
# VITE_GITHUB_REPO=couple-budget

# Optional: Specify the branch to sync (default: main)
# VITE_GITHUB_BRANCH=main

# Password protection (default: 260517)
# VITE_APP_PASSWORD=your_password
